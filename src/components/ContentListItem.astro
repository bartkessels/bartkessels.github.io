---
import { ChevronRight } from 'lucide-astro';

interface Props {
  href: string;
  index?: number;
  title: string;
  description?: string;
  image?: string;
}

const { href, index, title, description, image } = Astro.props;
---

<a
  href={href}
  class="group flex items-center gap-4 p-4 rounded-lg border border-border hover:border-accent/30 hover:bg-accent/5 transition-all"
>
  {index !== undefined && (
    <span class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/10 text-accent text-sm font-bold flex items-center justify-center">
      {index}
    </span>
  )}
  {image && (
    <div class="w-12 h-12 rounded-lg overflow-hidden bg-muted flex-shrink-0">
      <img src={image} alt={title} class="w-full h-full object-cover" />
    </div>
  )}
  <div class="flex-1 min-w-0">
    <p class="font-medium text-foreground group-hover:text-accent transition-colors">
      {title}
    </p>
    {description && (
      <p class="text-sm text-muted line-clamp-1 mt-0.5">{description}</p>
    )}
  </div>
  <ChevronRight class="h-4 w-4 text-muted group-hover:text-accent transition-colors flex-shrink-0" aria-hidden="true" />
</a>
