---
import { ChevronLeft, ChevronRight, ChevronsLeft, ChevronsRight } from 'lucide-astro';

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function getPageUrl(page: number): string {
  if (page === 1) {
    return baseUrl;
  }
  return `${baseUrl}/${page}`;
}

const showFirst = currentPage > 2;
const showLast = currentPage < totalPages - 1;
const showPrev = currentPage > 1;
const showNext = currentPage < totalPages;

// Generate page numbers to show
const pages: (number | 'ellipsis')[] = [];
const range = 1; // Show 1 page on each side of current

for (let i = 1; i <= totalPages; i++) {
  if (
    i === 1 ||
    i === totalPages ||
    (i >= currentPage - range && i <= currentPage + range)
  ) {
    pages.push(i);
  } else if (
    pages[pages.length - 1] !== 'ellipsis'
  ) {
    pages.push('ellipsis');
  }
}
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-1" aria-label="Pagination">
    {/* First page */}
    {showFirst && (
      <a
        href={getPageUrl(1)}
        class="p-2 rounded-md text-muted hover:text-foreground hover:bg-muted/10 transition-colors"
        aria-label="Go to first page"
      >
        <ChevronsLeft class="h-5 w-5" />
      </a>
    )}

    {/* Previous page */}
    {showPrev && (
      <a
        href={getPageUrl(currentPage - 1)}
        class="p-2 rounded-md text-muted hover:text-foreground hover:bg-muted/10 transition-colors"
        aria-label="Go to previous page"
      >
        <ChevronLeft class="h-5 w-5" />
      </a>
    )}

    {/* Page numbers */}
    <div class="flex items-center gap-1 mx-2">
      {pages.map((page) => (
        page === 'ellipsis' ? (
          <span class="px-2 text-muted">...</span>
        ) : (
          <a
            href={getPageUrl(page)}
            class:list={[
              'min-w-[2.5rem] h-10 flex items-center justify-center rounded-md text-sm font-medium transition-colors',
              page === currentPage
                ? 'bg-accent text-accent-foreground'
                : 'text-muted hover:text-foreground hover:bg-muted/10',
            ]}
            aria-label={`Go to page ${page}`}
            aria-current={page === currentPage ? 'page' : undefined}
          >
            {page}
          </a>
        )
      ))}
    </div>

    {/* Next page */}
    {showNext && (
      <a
        href={getPageUrl(currentPage + 1)}
        class="p-2 rounded-md text-muted hover:text-foreground hover:bg-muted/10 transition-colors"
        aria-label="Go to next page"
      >
        <ChevronRight class="h-5 w-5" />
      </a>
    )}

    {/* Last page */}
    {showLast && (
      <a
        href={getPageUrl(totalPages)}
        class="p-2 rounded-md text-muted hover:text-foreground hover:bg-muted/10 transition-colors"
        aria-label="Go to last page"
      >
        <ChevronsRight class="h-5 w-5" />
      </a>
    )}
  </nav>
)}
