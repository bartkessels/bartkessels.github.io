---
interface PlantScheduleEntry {
  name: string;
  slug?: string;
  sowIndoors?: number[];
  moveOutdoors?: number[];
  harvest?: number[];
}

interface Props {
  plants: PlantScheduleEntry[];
}

const { plants } = Astro.props;

const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

const SOW_COLOR     = '#3B82F6';
const MOVE_COLOR    = '#059669';
const HARVEST_COLOR = '#F59E0B';
const EMPTY_COLOR   = '#E5E7EB';

function getBlockStyle(month: number, sowIndoors: number[], moveOutdoors: number[], harvest: number[]): string {
  const colors: string[] = [];
  if (sowIndoors.includes(month))   colors.push(SOW_COLOR);
  if (moveOutdoors.includes(month)) colors.push(MOVE_COLOR);
  if (harvest.includes(month))      colors.push(HARVEST_COLOR);

  if (colors.length === 0) return `background-color: ${EMPTY_COLOR}`;
  if (colors.length === 1) return `background-color: ${colors[0]}`;
  if (colors.length === 2)
    return `background: linear-gradient(135deg, ${colors[0]} 50%, ${colors[1]} 50%)`;
  return `background: linear-gradient(135deg, ${colors[0]} 33.33%, ${colors[1]} 33.33%, ${colors[1]} 66.66%, ${colors[2]} 66.66%)`;
}

function getAriaLabel(month: number, label: string, sowIndoors: number[], moveOutdoors: number[], harvest: number[]): string {
  const events: string[] = [];
  if (sowIndoors.includes(month))   events.push('sow indoors');
  if (moveOutdoors.includes(month)) events.push('move outdoors');
  if (harvest.includes(month))      events.push('harvest');
  return events.length ? `${label}: ${events.join(', ')}` : label;
}

function getTooltip(month: number, sowIndoors: number[], moveOutdoors: number[], harvest: number[]): string | undefined {
  const events: string[] = [];
  if (sowIndoors.includes(month))   events.push('Sow indoors');
  if (moveOutdoors.includes(month)) events.push('Move outdoors');
  if (harvest.includes(month))      events.push('Harvest');
  return events.length ? events.join(', ') : undefined;
}
---

<div class="plant-schedule-list not-prose my-6 rounded-xl border border-border overflow-hidden">
  {/* Month header */}
  <div class="plant-schedule-list-header grid items-center gap-2 px-4 py-2 border-b border-border bg-card">
    <span class="text-xs font-medium text-muted" aria-hidden="true" />
    <div class="schedule-months-grid grid grid-cols-12 gap-1">
      {months.map((label, i) => (
        <span
          class="schedule-col-label text-xs text-muted text-center leading-none py-0.5 rounded-sm transition-colors"
          data-col={i + 1}
        >
          {label}
        </span>
      ))}
    </div>
  </div>

  {/* Plant rows */}
  {plants.map(({ name, slug, sowIndoors = [], moveOutdoors = [], harvest = [] }) => (
    <div class="plant-schedule-list-row grid items-center gap-2 px-4 py-2">
      {slug ? (
        <a href={`/gardening/plants/${slug}`} class="text-sm font-medium text-foreground hover:text-accent transition-colors truncate pr-2">{name}</a>
      ) : (
        <span class="text-sm font-medium text-foreground truncate pr-2">{name}</span>
      )}
      <div class="schedule-months-grid grid grid-cols-12 gap-1" role="list" aria-label={`${name} schedule`}>
        {months.map((label, i) => {
          const month = i + 1;
          return (
            <div
              class="schedule-col-cell aspect-square rounded-sm transition-all"
              data-col={month}
              title={getTooltip(month, sowIndoors, moveOutdoors, harvest)}
              style={getBlockStyle(month, sowIndoors, moveOutdoors, harvest)}
              aria-label={getAriaLabel(month, label, sowIndoors, moveOutdoors, harvest)}
              role="listitem"
            />
          );
        })}
      </div>
    </div>
  ))}

  {/* Legend */}
  <div class="flex flex-wrap gap-4 px-4 py-3 border-t border-border bg-card">
    <span class="flex items-center gap-1.5 text-xs text-muted">
      <span class="inline-block w-3 h-3 rounded-sm sow-indoors-swatch" aria-hidden="true" />
      Sow indoors
    </span>
    <span class="flex items-center gap-1.5 text-xs text-muted">
      <span class="inline-block w-3 h-3 rounded-sm move-outdoors-swatch" aria-hidden="true" />
      Move outdoors
    </span>
    <span class="flex items-center gap-1.5 text-xs text-muted">
      <span class="inline-block w-3 h-3 rounded-sm harvest-swatch" aria-hidden="true" />
      Harvest
    </span>
  </div>
</div>

<style>
  .plant-schedule-list-header,
  .plant-schedule-list-row {
    grid-template-columns: 10rem 1fr;
  }

  @media (max-width: 480px) {
    .plant-schedule-list-header,
    .plant-schedule-list-row {
      grid-template-columns: 6rem 1fr;
    }
  }

  .plant-schedule-list-row:nth-child(odd) {
    background-color: var(--color-card, #ffffff);
  }

  .plant-schedule-list-row:nth-child(even) {
    background-color: color-mix(in srgb, var(--color-muted, #6B7280) 2%, transparent);
  }

  .move-outdoors-swatch { background-color: #059669; }
  .harvest-swatch       { background-color: #F59E0B; }

  .schedule-col-cell.is-dimmed {
    opacity: 0.4;
  }

  .schedule-col-label.is-current-month {
    color: var(--color-accent);
    font-weight: 700;
  }
</style>

<script>
  const currentMonth = new Date().getMonth() + 1; // 1–12

  document.querySelectorAll<HTMLElement>('[data-col]').forEach(el => {
    const col = Number(el.dataset.col);
    if (col === currentMonth) {
      el.classList.add('is-current-month');
    } else {
      el.classList.add('is-dimmed');
    }
  });
</script>
