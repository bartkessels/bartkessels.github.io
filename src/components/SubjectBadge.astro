---
interface Props {
  subject: string;
  size?: 'sm' | 'md';
  color?: string;
}

const { subject, size = 'sm', color = 'bg-gray-100 text-gray-800' } = Astro.props;
const sizeClasses = size === 'sm' 
  ? 'px-2.5 py-0.5 text-xs' 
  : 'px-3 py-1 text-sm';
---

<span class=`inline-flex items-center rounded-full font-medium ${color} ${sizeClasses}`>
  <span class="sr-only">Category: </span>{subject}
</span>
