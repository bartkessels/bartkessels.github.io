---
import { FileCode } from 'lucide-astro';

interface Props {
  filename?: string;
}

const { filename } = Astro.props;
---

<div class="code-block">
  <div class="code-block-header">
    <span class="code-block-window-buttons" aria-hidden="true">
      <span class="code-block-btn code-block-btn--close" />
      <span class="code-block-btn code-block-btn--minimize" />
      <span class="code-block-btn code-block-btn--maximize" />
    </span>
    {filename && (
      <span class="code-block-filename">
        <FileCode class="h-4 w-4" aria-hidden="true" />
        {filename}
      </span>
    )}
  </div>
  <slot />
</div>
