---
import { BookOpen, Calendar } from 'lucide-astro';
import { formatDate } from '@/utils/content';

interface Props {
  title: string;
  description: string;
  date: Date;
  image: string;
  slug: string;
  postCount: number;
}

const { title, description, date, image, slug, postCount } = Astro.props;

const formattedDate = formatDate(date);
---

<article class="group relative focus-within:ring-2 focus-within:ring-accent focus-within:ring-offset-2 focus-within:ring-offset-background focus-within:rounded-xl">
  <div class="bg-card rounded-xl overflow-hidden border-2 border-accent/20 hover:border-accent/50 hover:shadow-xl transition-all duration-300">
    <div class="aspect-[21/9] overflow-hidden bg-muted">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
    <div class="p-6">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent/10 text-accent">
          <BookOpen class="h-3.5 w-3.5" aria-hidden="true" />
          Story Series
        </span>
        <span class="text-xs text-muted">
          {postCount} {postCount === 1 ? 'post' : 'posts'}
        </span>
      </div>

      <h3 class="text-xl font-semibold text-card-foreground group-hover:text-accent transition-colors mb-2 line-clamp-2 h-14">
        <a
          href={`/stories/${slug}`}
          class="text-current hover:text-current after:absolute after:inset-0 after:content-[''] focus-visible:outline-none"
        >
          {title}
        </a>
      </h3>

      <p class="text-muted text-sm mb-4 line-clamp-2">
        {description}
      </p>

      <time datetime={date.toISOString()} class="flex items-center gap-1.5 text-xs text-muted">
        <Calendar class="h-3.5 w-3.5" aria-hidden="true" />
        {formattedDate}
      </time>
    </div>
  </div>
</article>
