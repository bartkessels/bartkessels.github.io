---
import { getBlogPosts } from '@/repositories/blog.repository';
import ContentListItem from './ContentListItem.astro';

interface Props {
  subject: string;
  currentSlug: string;
}

const { subject, currentSlug } = Astro.props;

const allPosts = await getBlogPosts();
const related = allPosts
  .filter((p) => p.data.subject === subject && p.id !== currentSlug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

{related.length > 0 && (
  <aside class="mt-12 pt-10 border-t border-border">
    <h2 class="text-2xl font-semibold text-foreground mb-6">Related Posts</h2>
    <div class="space-y-3">
      {related.map((post) => (
        <ContentListItem
          href={`/${post.data.subject}/${post.id}`}
          title={post.data.title}
          description={post.data.description}
          image={post.data.image}
        />
      ))}
    </div>
  </aside>
)}
