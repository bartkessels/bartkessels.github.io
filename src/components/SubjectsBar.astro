---
import type { SimplifiedSubject } from '@/models/subject.model';

interface Props {
    subjects: SimplifiedSubject[]
}

const { subjects } = Astro.props;
const isActive = (href: string) => Astro.url.pathname.includes(`/${href}`)
---

<div class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center gap-1 overflow-x-auto py-1 scrollbar-none" aria-label="Topics">
        {subjects.map(subject => (
        <a
            href=`/${subject.href}`
            aria-current={isActive(subject.href) ? 'page' : undefined}
            class:list={[
            'flex-shrink-0 px-3 py-1.5 text-xs font-medium rounded-md transition-colors whitespace-nowrap',
            isActive(subject.href)
                ? 'text-accent bg-accent/10'
                : 'text-muted hover:text-foreground hover:bg-muted/10'
            ]}
        >
            {subject.name}
        </a>
        ))}
    </nav>
    </div>
</div>
