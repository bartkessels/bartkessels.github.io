---
import { Award, ExternalLink, CalendarCheck, CalendarX } from '@lucide/astro';

interface Props {
  name: string;
  issuer: string;
  issuerLogo?: string;
  issueDate: string;
  isExpired: boolean;
  expiryDate?: string;
  credentialId?: string;
  credentialUrl?: string;
}

const { name, issuer, issuerLogo, issueDate, isExpired, expiryDate, credentialId, credentialUrl } = Astro.props;
---

<article class:list={[
  "group relative bg-card rounded-xl border transition-all duration-300 overflow-hidden",
  isExpired
    ? "border-border opacity-70"
    : "border-border"
]}>
  {/* Top accent stripe */}
  <div class:list={[
    "h-1 w-full",
    isExpired ? "bg-muted/40" : "bg-accent/80"
  ]} />

  <div class="p-5 flex flex-col gap-4">
    {/* Header row */}
    <div class="flex items-start gap-3">
      {issuerLogo ? (
        <img
          src={issuerLogo}
          alt={issuer}
          class="w-10 h-10 rounded-lg object-contain p-1 flex-shrink-0"
          loading="lazy"
        />
      ) : (
        <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
          <Award class="w-5 h-5 text-accent" aria-hidden="true" />
        </div>
      )}

      <div class="flex-1 min-w-0">
        <p class="text-xs font-medium text-muted uppercase tracking-wide leading-none mb-1">{issuer}</p>
        <h3 class="text-sm font-semibold text-foreground leading-snug">{name}</h3>
      </div>

      {/* Status badge */}
      {isExpired ? (
        <span class="flex-shrink-0 inline-flex items-center gap-1 text-xs font-medium text-muted bg-muted/10 border border-border px-2 py-0.5 rounded-full">
          Expired
        </span>
      ) : (
        <span class="flex-shrink-0 inline-flex items-center gap-1 text-xs font-medium text-accent bg-accent/10 border border-accent/20 px-2 py-0.5 rounded-full">
          Active
        </span>
      )}
    </div>

    {/* Dates */}
    <div class="flex items-center gap-4 text-xs text-muted">
      <span class="inline-flex items-center gap-1.5">
        <CalendarCheck class="w-3.5 h-3.5" aria-hidden="true" />
        Issued {issueDate}
      </span>
      {expiryDate && (
        <span class="inline-flex items-center gap-1.5">
          <CalendarX class="w-3.5 h-3.5" aria-hidden="true" />
          {isExpired ? 'Expired' : 'Expires'} {expiryDate}
        </span>
      )}
    </div>

    {/* Footer */}
    {(credentialId || credentialUrl) && (
      <div class="flex items-center justify-between pt-1 border-t border-border gap-3">
        {credentialId && (
          <p class="text-xs text-muted truncate font-mono">
            ID: {credentialId}
          </p>
        )}
        {credentialUrl && (
          <a
            href={credentialUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto flex-shrink-0 inline-flex items-center gap-1.5 text-xs font-medium text-accent hover:text-accent/80 transition-colors"
          >
            Verify
            <ExternalLink class="w-3 h-3" aria-hidden="true" />
          </a>
        )}
      </div>
    )}
  </div>
</article>
