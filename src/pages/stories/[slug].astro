---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { getStories } from '@/repositories/stories.repository';
import { getBlogPostBySlug } from '@/repositories/blog.repository';
import { Calendar, BookOpen } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentListItem from '@/components/ContentListItem.astro';
import { formatDate } from '@/utils/content';

export const getStaticPaths = (async () => {
  const stories = await getStories();
  
  return stories.map((story) => ({
    params: { slug: story.id },
    props: { story },
  }));
}) satisfies GetStaticPaths;

const { story } = Astro.props;
const { Content } = await render(story);

// Get all posts in this story
const storyPosts = await Promise.all(
  story.data.posts.map(async (postSlug) => {
    const post = await getBlogPostBySlug(postSlug);
    return post;
  })
);

const formattedDate = formatDate(story.data.date);
---

<BaseLayout 
  title={story.data.title} 
  description={story.data.description}
  image={story.data.image}
>
  <article>
    {/* Hero Image */}
    <figure>
      <div class="w-full aspect-[21/9] bg-muted overflow-hidden">
        <img
          src={story.data.image}
          alt={story.data.title}
          class="w-full h-full object-cover"
        />
      </div>
      <figcaption class="text-center text-xs text-muted/70 italic py-2 px-4 border-t border-border/50">
        {story.data.caption}
      </figcaption>
    </figure>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      {/* Header */}
      <header class="mb-12">
        <div class="flex items-center gap-2 mb-4">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent/10 text-accent">
            <BookOpen class="h-3.5 w-3.5" />
            Story Series
          </span>
          <span class="text-sm text-muted">
            {storyPosts.length} {storyPosts.length === 1 ? 'post' : 'posts'}
          </span>
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4 leading-tight">
          {story.data.title}
        </h1>

        <p class="text-lg text-muted mb-6">
          {story.data.description}
        </p>

        <div class="flex items-center gap-2 text-sm text-muted border-b border-border pb-6">
          <Calendar class="h-4 w-4" />
          Started {formattedDate}
        </div>
      </header>

      {/* Story Introduction */}
      <div class="prose mb-16">
        <Content />
      </div>

      {/* Story Posts */}
      <section>
        <h2 class="text-2xl font-semibold text-foreground mb-6">Posts in this series</h2>
        
        <div class="space-y-3">
          {storyPosts.map((post, index) => (
            <ContentListItem
              href={`/${post.data.subject}/${post.id}`}
              index={index + 1}
              title={post.data.title}
              image={post.data.image}
              description={post.data.description}
            />
          ))}
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
