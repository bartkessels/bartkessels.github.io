---
import { BookOpen, Leaf } from '@lucide/astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getReadingTime } from '@/utils/content';
import SectionHeader from '@/components/SectionHeader.astro';
import GardeningJournalCard from '@/components/GardeningJournalCard.astro';
import { getGardeningViewModel } from '@/factories/view-model.factory';
import SubjectsBar from '@/components/SubjectsBar.astro';

const viewModel = getGardeningViewModel();
const overviewPage = await viewModel.getOverviewPage();
---

<BaseLayout
  title={overviewPage.page.data.title}
  description={overviewPage.page.data.description}
  showSubjectsBar={overviewPage.page.data.show_subjects}
  activePageId={overviewPage.page.id}>
  <SubjectsBar subjects={overviewPage.subjects} slot="subjects-bar" />
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {/* Header */}
    <SectionHeader page={overviewPage.page} />

    {overviewPage.itemsPerYear.length === 0 ? (
      <p class="text-muted">Nothing here yet. Check back soon!</p>
    ) : (
      <div class="space-y-16">
        {overviewPage.itemsPerYear.map(year => (
          <section>
            {/* Year heading */}
            <div class="flex items-center gap-3 mb-8 pb-3 border-b border-border">
              <a
                href={`/gardening/${year.year.id}`}
                class="text-3xl font-bold text-foreground hover:text-accent transition-colors"
              >
                {year.year.data.name}
              </a>
              <span class="text-sm text-muted">
                {year.journalEntries.length} {year.journalEntries.length === 1 ? 'journal entry' : 'journal entries'} &middot; {year.plants.length} plants
              </span>
            </div>

            <div class="grid gap-10 lg:grid-cols-3">
              <div class="lg:col-span-2">
                <div class="flex items-center gap-2 mb-4">
                  <BookOpen class="h-4 w-4 text-accent" aria-hidden="true" />
                  <h3 class="text-lg font-semibold text-foreground">Journal</h3>
                </div>
                {year.journalEntries.length > 0 ? (
                  <div class="space-y-4">
                    {year.journalEntries.map(journalEntry => (
                      <GardeningJournalCard
                        title={journalEntry.data.title}
                        description={journalEntry.data.description}
                        date={journalEntry.data.date}
                        author={journalEntry.data.author}
                        image={journalEntry.data.image}
                        slug={journalEntry.id}
                        readingTime={getReadingTime(journalEntry.body)}
                      />
                    ))}
                  </div>
                ) : (
                  <p class="text-sm text-muted">No journal entries for {year.year.data.name}.</p>
                )}
              </div>

              <div>
                <div class="flex items-center gap-2 mb-4">
                  <Leaf class="h-4 w-4 text-accent" aria-hidden="true" />
                  <h3 class="text-lg font-semibold text-foreground">Plants</h3>
                  <a
                    href={`/gardening/${year.year.id}/schedule`}
                    class="ml-auto text-xs text-accent hover:underline"
                  >
                    View schedule &RightArrow;
                  </a>
                </div>
                {year.plants.length > 0 ? (
                  <div class="space-y-5">
                    {year.plants.map(plantsPerYear => (
                      <div>
                        <h4 class="text-xs font-semibold text-muted uppercase tracking-wide mb-2">{plantsPerYear.category}</h4>
                        <div class="space-y-2">
                          {plantsPerYear.plants.map(plant => (
                            <a
                              href={`/gardening/plants/${plant.id.split('/').at(-1)}`}
                              class="group flex items-center gap-3 p-2.5 rounded-lg border border-border hover:border-accent/30 hover:bg-accent/5 transition-all"
                            >
                              <div class="w-9 h-9 rounded-lg overflow-hidden bg-muted flex-shrink-0">
                                <img
                                  src={plant.data.image}
                                  alt={plant.data.name}
                                  class="w-full h-full object-cover"
                                  loading="lazy"
                                />
                              </div>
                              <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors">
                                {plant.data.name}
                              </span>
                            </a>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="text-sm text-muted">No plants recorded for {year.year.data.name}.</p>
                )}
              </div>
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

