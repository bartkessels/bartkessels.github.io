---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { Calendar, BookOpen, Clock, User } from '@lucide/astro';
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import TagsList from '@/components/TagsList.astro';
import { getGardeningViewModel } from '@/factories/view-model.factory';
import { getReadingTime } from '@/utils/content';

export const getStaticPaths = (async () => {
  const viewModel = getGardeningViewModel();
  const journalPages = await viewModel.getJournalPages();

  return journalPages.map(page => ({
    params: {
      slug: page.journalEntry.id
    },
    props: {
      journal: page.journalEntry,
      formattedDate: page.formattedDate
    }
  }));
}) satisfies GetStaticPaths;

const { journal, formattedDate } = Astro.props;
const { Content } = await render(journal);
const readingTime = getReadingTime(journal.body);
---

<ArticleLayout
  title={journal.data.title}
  description={`Garden journal entry from ${formattedDate}`}
  image={journal.data.image}
  imageCaption={journal.data.caption}
  activePageId="gardening"
  tags={journal.data.tags}
>
  <header class="mb-8">
    <div class="flex flex-wrap items-center gap-2 mb-2">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent/10 text-accent">
        <BookOpen class="h-3.5 w-3.5" />
        Journal Entry
      </span>
    </div>
    {(journal.data.tags ?? []).length > 0 && (
      <div class="mb-4">
        <TagsList tags={journal.data.tags ?? []} />
      </div>
    )}

    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4 leading-tight">
      {journal.data.title}
    </h1>

    <p class="text-lg text-muted mb-6">
      {journal.data.description}
    </p>

    <div class="flex flex-wrap items-center gap-6 text-sm text-muted border-b border-border pb-6">
      <span class="flex items-center gap-2">
        <User class="h-4 w-4" aria-hidden="true" />
        {journal.data.author}
      </span>
      <time datetime={journal.data.date.toISOString()} class="flex items-center gap-2">
        <Calendar class="h-4 w-4" aria-hidden="true" />
        {formattedDate}
      </time>
      {readingTime && (
        <span class="flex items-center gap-2">
          <Clock class="h-4 w-4" aria-hidden="true" />
          {readingTime} min read
        </span>
      )}
    </div>
  </header>

  <div class="prose">
    <Content />
  </div>
</ArticleLayout>
