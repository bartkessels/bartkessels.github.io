---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { getReadingTime } from '@/utils/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { BookOpen, Leaf } from '@lucide/astro';
import GardeningJournalCard from '@/components/GardeningJournalCard.astro';
import { getGardeningViewModel } from '@/factories/view-model.factory';
import SubjectsBar from '@/components/SubjectsBar.astro';

export const getStaticPaths = (async () => {
  const viewModel = getGardeningViewModel();
  const overviewPages = await viewModel.getYearOverviewPages();

  return overviewPages.map(page => ({
    params: { year: page.year.id },
    props: {
      subjectName: page.year.data.name,
      subjectEntry: page.year,
      journals: page.journalEntries,
      plants: page.plants,
      subjects: page.subjects
    },
  }));
}) satisfies GetStaticPaths;

const { subjectName, subjects, subjectEntry, journals, plants } = Astro.props;
const { Content } = await render(subjectEntry);
---

<BaseLayout
  title={`${subjectName} — Gardening`}
  description={`Gardening journal entries and plant profiles for ${subjectName}.`}
  activePageId="gardening"
  showSubjectsBar={true}
>
  <SubjectsBar subjects={subjects} slot="subjects-bar" />
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">{subjectName}</h1>
      <div class="text-lg text-muted max-w-2xl prose prose-muted">
        <Content />
      </div>
    </header>

    {journals.length === 0 && plants.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-muted text-lg">No entries found yet.</p>
        <a href="/gardening" class="inline-block mt-4 text-accent hover:text-accent/80 transition-colors">
          ← Back to Gardening
        </a>
      </div>
    ) : (
      <div class="grid gap-12 lg:grid-cols-3">
        {/* Journal entries */}
        <section class="lg:col-span-2">
          <div class="flex items-center gap-2 mb-6">
            <BookOpen class="h-5 w-5 text-accent" />
            <h2 class="text-2xl font-semibold text-foreground">Journal</h2>
          </div>
          {journals.length > 0 ? (
            <div class="space-y-6">
              {journals.map((entry) => (
                <GardeningJournalCard
                  title={entry.data.title}
                  description={entry.data.description}
                  date={entry.data.date}
                  author={entry.data.author}
                  image={entry.data.image}
                  slug={entry.id.split('/').pop()!.replace(/\.mdx?$/, '')}
                  readingTime={getReadingTime(entry.body)}
                />
              ))}
            </div>
          ) : (
            <p class="text-muted">No journal entries for this season yet.</p>
          )}
        </section>

        {/* Plants grouped by category */}
        <section>
          <div class="flex items-center gap-2 mb-6">
            <Leaf class="h-5 w-5 text-accent" />
            <h2 class="text-2xl font-semibold text-foreground">Plants</h2>
            <a
              href={`/gardening/${Astro.params.year}/schedule`}
              class="ml-auto text-xs text-accent hover:underline"
            >
              View schedule &RightArrow;
            </a>
          </div>
          {plants.length > 0 ? (
            <div class="space-y-6">
              {plants.map(plantsByCategory => (
                <div>
                  <h3 class="text-xs font-semibold text-muted uppercase tracking-wide mb-2">{plantsByCategory.category}</h3>
                  <div class="space-y-2">
                    {plantsByCategory.plants.map(plant => (
                      <a
                        href={`/gardening/plants/${plant.id.split('/').pop()!.replace(/\.mdx?$/, '')}`}
                        class="group flex items-center gap-3 p-3 rounded-lg border border-border hover:border-accent/30 hover:bg-accent/5 transition-all"
                      >
                        <div class="w-10 h-10 rounded-lg overflow-hidden bg-muted flex-shrink-0">
                          <img
                            src={plant.data.image}
                            alt={plant.data.name}
                            class="w-full h-full object-cover"
                            loading="lazy"
                          />
                        </div>
                        <div>
                          <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors block">
                            {plant.data.name}
                          </span>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-muted">No plants recorded for this season yet.</p>
          )}
        </section>
      </div>
    )}
  </div>
</BaseLayout>
