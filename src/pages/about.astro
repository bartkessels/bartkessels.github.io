---
import { Mail } from '@lucide/astro';
import CertificateCard from '@/components/CertificateCard.astro';
import GitHubIcon from '@/components/GitHubIcon.astro';
import LinkedInIcon from '@/components/LinkedInIcon.astro';
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAboutViewModel } from '@/factories/view-model.factory';

const viewModel = getAboutViewModel();
const aboutPage = await viewModel.getPage();

const { Content } = await render(aboutPage.page);
---

<BaseLayout
  title={aboutPage.page.data.title}
  description={aboutPage.page.data.description}
  activePageId={aboutPage.page.id}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {/* Header */}
    <header class="mb-12 text-center">
      <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-muted overflow-hidden">
        <img
          src="/images/bartkessels.jpg"
          alt="Bart Kessels"
          class="w-full h-full object-cover"
        />
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">Bart Kessels</h1>
      <p class="text-xl text-muted">Software Developer & Outdoor Enthusiast</p>
    </header>

    {/* Bio */}
    <section class="prose max-w-none mb-12">
      <Content />
    </section>

    {/* Certificates */}
    {aboutPage.certificates.length > 0 && (
      <section class="border-t border-border pt-8">
        <h2 class="text-xl font-semibold text-foreground mb-2 text-center">Certifications</h2>
        <p class="text-sm text-muted text-center mb-6">Certificates and credentials</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {aboutPage.certificates.map(cert => (
            <CertificateCard
              name={cert.certificate.data.name}
              issuer={cert.certificate.data.issuer}
              issuerLogo={cert.certificate.data.issuerLogo}
              issueDate={cert.issueDate}
              isExpired={cert.isExpired}
              expiryDate={cert.expiryDate}
              credentialId={cert.certificate.data.credentialId}
              credentialUrl={cert.certificate.data.credentialUrl}
            />
          ))}
        </div>
      </section>
    )}

    {/* Social Links */}
    <section class="border-t border-border pt-8 mt-8">
      <h2 class="text-xl font-semibold text-foreground mb-6 text-center">Get in Touch</h2>
      <div class="flex items-center justify-center gap-6">
        <a
          href="https://github.com/bartkessels"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 rounded-lg border border-border hover:border-accent hover:bg-accent/5 transition-all text-muted hover:text-foreground"
        >
          <GitHubIcon class="h-5 w-5" />
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/bartkessels"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 rounded-lg border border-border hover:border-accent hover:bg-accent/5 transition-all text-muted hover:text-foreground"
        >
          <LinkedInIcon class="h-5 w-5" />
          LinkedIn
        </a>
        <a
          href="mailto:hello@bartkessels.net"
          class="flex items-center gap-2 px-4 py-2 rounded-lg border border-border hover:border-accent hover:bg-accent/5 transition-all text-muted hover:text-foreground"
        >
          <Mail class="h-5 w-5" />
          Email
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
