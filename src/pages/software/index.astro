---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SoftwareCard from '@/components/SoftwareCard.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { getSoftwareViewModel } from '@/factories/view-model.factory';

const viewModel = getSoftwareViewModel();
const overview = await viewModel.getOverview();
---

<BaseLayout
  title={overview.page.data.title}
  description={overview.page.data.description}
  activePageId={overview.page.id}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <SectionHeader page={overview.page} />

    {overview.projects.length > 0 && (
      <section class="mb-16">
        <div class="grid gap-6 md:grid-cols-2">
          {overview.projects.map(project => (
            <SoftwareCard
              slug={project.id}
              name={project.data.name}
              description={project.data.description}
              logo={project.data.logo}
              repository={project.data.repository}
              website={project.data.website}
            />
          ))}
        </div>
      </section>
    )}

    {overview.projects.length === 0 && (
      <div class="text-center py-12">
        <p class="text-muted text-lg">No projects published yet. Check back soon!</p>
      </div>
    )}
  </div>
</BaseLayout>
