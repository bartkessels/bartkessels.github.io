---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { subjectSlug } from '@/utils/content';
import { getSoftware } from '@/repositories/software.repository';
import { getSubjectsForSection } from '@/repositories/subject.repository';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SoftwareCard from '@/components/SoftwareCard.astro';

export const getStaticPaths = (async () => {
  const subjects = await getSubjectsForSection('software');
  const allSoftware = await getSoftware();

  return subjects.map((subjectEntry) => {
    const subject = subjectSlug(subjectEntry.id);
    const projects = allSoftware
      .filter((project) => project.data.subject === subject)
      .sort((a, b) => a.data.name.localeCompare(b.data.name));

    return {
      params: { subject },
      props: { subjectName: subjectEntry.data.name, subjectEntry, projects },
    };
  });
}) satisfies GetStaticPaths;

const { subjectName, subjectEntry, projects } = Astro.props;
const { Content } = await render(subjectEntry);
---

<BaseLayout
  title={`${subjectName} – Software`}
  description={`Open source software projects related to ${subjectName}.`}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <a href="/software" class="text-sm text-muted hover:text-foreground transition-colors mb-4 inline-block">
        ← Back to Software
      </a>
      <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">{subjectName}</h1>
      <div class="text-lg text-muted max-w-2xl prose prose-muted">
        <Content />
      </div>
    </header>

    {projects.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <SoftwareCard
            slug={project.id}
            name={project.data.name}
            description={project.data.description}
            logo={project.data.logo}
            repository={project.data.repository}
            website={project.data.website}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-muted text-lg">No projects found for this subject yet.</p>
        <a href="/software" class="inline-block mt-4 text-accent hover:text-accent/80 transition-colors">
          View all software projects
        </a>
      </div>
    )}
  </div>
</BaseLayout>
