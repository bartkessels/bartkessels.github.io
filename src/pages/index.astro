---
import { ArrowRight } from '@lucide/astro';
import GitHubIcon from '@/components/GitHubIcon.astro';
import LinkedInIcon from '@/components/LinkedInIcon.astro';
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import SoftwareCard from '@/components/SoftwareCard.astro';
import TrailCard from '@/components/TrailCard.astro';
import StoryCard from '@/components/StoryCard.astro';
import { getReadingTime, getSectionLabel } from '@/utils/content';
import { getHomeViewModel } from '@/factories/view-model.factory';

const viewModel = getHomeViewModel();
const overviewPage = await viewModel.getOverviewPage();

const { Content } = await render(overviewPage.page);
---

<BaseLayout
  title="Bart Kessels — Software Developer & Outdoor Enthusiast"
  description={overviewPage.page.data.description}
  activePageId={overviewPage.page.id}
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="max-w-3xl">
      <div class="w-20 h-20 mb-8 rounded-full bg-muted overflow-hidden">
        <img
          src="/images/bartkessels.jpg"
          alt="Bart Kessels"
          class="w-full h-full object-cover"
          width="80"
          height="80"
        />
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-foreground mb-6 tracking-tight">
        Hi, I'm <span class="text-accent">Bart Kessels</span>
      </h1>
      <p class="text-xl md:text-2xl text-muted mb-8 leading-relaxed">
        <Content />

        <br>
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-white rounded-lg font-medium hover:bg-accent/90 transition-colors no-underline"
        >
          Read the blog
          <ArrowRight class="h-4 w-4" />
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-6 py-3 border border-border rounded-lg font-medium text-foreground hover:bg-muted/10 transition-colors no-underline"
        >
          About me
        </a>
      </div>
      <div class="flex items-center gap-4 mt-8">
        <a href="https://github.com/bartkessels" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-foreground transition-colors no-underline">
          <GitHubIcon class="h-5 w-5" />
          <span class="sr-only">GitHub</span>
        </a>
        <a href="https://linkedin.com/in/bartkessels" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-foreground transition-colors no-underline">
          <LinkedInIcon class="h-5 w-5" />
          <span class="sr-only">LinkedIn</span>
        </a>
      </div>
    </div>
  </section>

  {/* Latest Blog Posts */}
  {overviewPage.latestPosts.length > 0 && (
    <section data-section="blog" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-border">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-semibold text-foreground">Latest posts</h2>
        <a href="/blog" class="inline-flex items-center gap-1 text-sm text-accent hover:text-accent/80 transition-colors no-underline font-medium">
          All posts <ArrowRight class="h-4 w-4" />
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {overviewPage.latestPosts.map(post => (
          <BlogCard
            title={post.post.data.title}
            description={post.post.data.description}
            date={post.post.data.date}
            author={post.post.data.author}
            subject={post.subject.data.name}
            subjectColor={post.subject.data.color}
            subjectId={post.subject.id}
            image={post.post.data.image}
            slug={post.post.id}
            readingTime={getReadingTime(post.post.body)}
          />
        ))}
      </div>
    </section>
  )}

  {/* Featured Story */}
  {overviewPage.latestStories.length > 0 && (
    <section data-section="stories" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-border">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-semibold text-foreground">Featured stories</h2>
        <a href="/stories" class="inline-flex items-center gap-1 text-sm text-accent hover:text-accent/80 transition-colors no-underline font-medium">
          All stories <ArrowRight class="h-4 w-4" />
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {overviewPage.latestStories.map(story => (
          <StoryCard
            title={story.data.title}
            description={story.data.description}
            date={story.data.date}
            image={story.data.image}
            slug={story.id}
            postCount={story.data.posts.length}
          />
        ))}
      </div>
    </section>
  )}

  {/* Software Projects */}
  {overviewPage.featuredSoftwareProjects.length > 0 && (
    <section data-section="software" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-border">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-semibold text-foreground">Software Projects</h2>
        <a href="/software" class="inline-flex items-center gap-1 text-sm text-accent hover:text-accent/80 transition-colors no-underline font-medium">
          All projects <ArrowRight class="h-4 w-4" />
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {overviewPage.featuredSoftwareProjects.map(project => (
          <SoftwareCard
            slug={project.id}
            name={project.data.name}
            description={project.data.description}
            logo={project.data.logo}
            repository={project.data.repository}
            website={project.data.website}
          />
        ))}
      </div>
    </section>
  )}

  {/* Latest Trail */}
  {overviewPage.latestTrails.length > 0 && (
    <section data-section="backpacking" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-border">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-semibold text-foreground">Latest trails</h2>
        <a href="/backpacking" class="inline-flex items-center gap-1 text-sm text-accent hover:text-accent/80 transition-colors no-underline font-medium">
          All trails <ArrowRight class="h-4 w-4" />
        </a>
      </div>
      <div class="max-w-sm">
        {overviewPage.latestTrails.map(trail => {
          const sectionLabel = getSectionLabel(trail.data.sections.length, trail.data.totalSections) ?? undefined;
          return (
            <TrailCard
              title={trail.data.title}
              description={trail.data.description}
              date={trail.data.date}
              country={trail.data.country}
              location={trail.data.location}
              distanceKm={trail.data.distanceKm}
              image={trail.data.image}
              slug={trail.id}
              sectionLabel={sectionLabel}
            />
          );
        })}
      </div>
    </section>
  )}
</BaseLayout>
