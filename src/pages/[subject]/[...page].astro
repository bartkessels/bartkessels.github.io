---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { getReadingTime } from '@/utils/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import Pagination from '@/components/Pagination.astro';
import { getBlogViewModel } from '@/factories/view-model.factory';
import SubjectsBar from '@/components/SubjectsBar.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const viewModel = getBlogViewModel();
  const overviewPages = await viewModel.getSubjectOverviewPages();

  return overviewPages.flatMap(page => paginate(page.posts, {
    params: {
      subject: page.subject.id
    },
    props: {
      subjectEntry: page.subject,
      subjects: page.subjects,
      pageEntry: page.page
    },
    pageSize: page.postsPerPage
  }));
}) satisfies GetStaticPaths;

const { page, pageEntry, subjectEntry, subjects } = Astro.props;
const { subject } = Astro.params;
const { Content } = await render(subjectEntry);
---

<BaseLayout
  showSubjectsBar={pageEntry.data.show_subjects}
  title={`${subjectEntry.data.name} Posts`} 
  description={`Articles about ${subjectEntry} development and related topics.`}
  activePageId={pageEntry.id}>
  <SubjectsBar subjects={subjects} slot="subjects-bar" />
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">
        {subjectEntry.data.name}
      </h1>
      <div class="text-lg text-muted max-w-2xl prose prose-muted">
        <Content />
      </div>
    </header>

    {page.data.length > 0 ? (
      <>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mb-12">
          {page.data.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              author={post.data.author}
              subject={post.data.subject}
              subjectId={subjectEntry.id}
              subject={subjectEntry.data.name}
              subjectColor={subjectEntry.data.color}
              image={post.data.image}
              slug={post.id}
              readingTime={getReadingTime(post.body)}
            />
          ))}
        </div>

        <Pagination
          currentPage={page.currentPage}
          totalPages={page.lastPage}
          baseUrl={`/${subject}`}
        />
      </>
    ) : (
      <div class="text-center py-12">
        <p class="text-muted text-lg">No posts found in this category yet.</p>
        <a href="/blog" class="inline-block mt-4 text-accent hover:text-accent/80 transition-colors">
          View all posts
        </a>
      </div>
    )}
  </div>
</BaseLayout>
