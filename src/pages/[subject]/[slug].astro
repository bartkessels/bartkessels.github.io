---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import { getBlogPosts, getBlogPostBySlug } from '@/repositories/blog.repository';
import { getReadingTime } from '@/utils/content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getStoryForPost } from '@/repositories/stories.repository';

export const getStaticPaths = (async () => {
  const posts = await getBlogPosts();
  
  return posts.map((post) => ({
    params: { subject: post.data.subject, slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = getReadingTime(post.body);

// Get story info if this post is part of a story
let storyInfo: {
  title: string;
  slug: string;
  prevPost?: { title: string; slug: string; subject: string };
  nextPost?: { title: string; slug: string; subject: string };
} | undefined;

const story = await getStoryForPost(post.id);
if (story) {
  const storyPosts = story.data.posts;
  const currentIndex = storyPosts.indexOf(post.id);
  
  let prevPost: { title: string; slug: string; subject: string } | undefined;
  let nextPost: { title: string; slug: string; subject: string } | undefined;
  
  if (currentIndex > 0) {
    const prevEntry = await getBlogPostBySlug(storyPosts[currentIndex - 1]);
    if (prevEntry) {
      prevPost = { title: prevEntry.data.title, slug: prevEntry.id, subject: prevEntry.data.subject };
    }
  }
  
  if (currentIndex < storyPosts.length - 1) {
    const nextEntry = await getBlogPostBySlug(storyPosts[currentIndex + 1]);
    if (nextEntry) {
      nextPost = { title: nextEntry.data.title, slug: nextEntry.id, subject: nextEntry.data.subject };
    }
  }
  
  storyInfo = {
    title: story.data.title,
    slug: story.id,
    prevPost,
    nextPost,
  };
}
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  author={post.data.author}
  subject={post.data.subject}
  image={post.data.image}
  imageCaption={post.data.caption}
  readingTime={readingTime}
  currentSlug={post.id}
  story={storyInfo}
>
  <Content />
</BlogLayout>
