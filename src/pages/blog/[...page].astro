---
import type { GetStaticPaths } from 'astro';
import { getReadingTime } from '@/utils/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import StoryCard from '@/components/StoryCard.astro';
import Pagination from '@/components/Pagination.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { getBlogViewModel } from '@/factories/view-model.factory';
import SubjectsBar from '@/components/SubjectsBar.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const viewModel = getBlogViewModel();
  const overview = await viewModel.getOverviewPage();
  
  return paginate(overview.posts, {
      pageSize: overview.postsPerPage,
      props: {
        stories: overview.stories,
        blogPage: overview.page,
        subjects: overview.subjects
    }
  });
}) satisfies GetStaticPaths;

const { page, stories, blogPage, subjects } = Astro.props;
---

<BaseLayout
  title={blogPage.data.title}
  description={blogPage.data.description}
  showSubjectsBar={blogPage.data.show_subjects}
  activePageId={blogPage.id}>
  <SubjectsBar subjects={subjects} slot="subjects-bar" />
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <SectionHeader page={blogPage} />

    {page.currentPage === 1 && stories.length > 0 && (
      <section data-section="stories" class="mb-16">
        <h2 class="text-2xl font-semibold text-foreground mb-6">Featured Stories</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {stories.map(story => (
            <StoryCard
              title={story.data.title}
              description={story.data.description}
              date={story.data.date}
              image={story.data.image}
              slug={story.id}
              postCount={story.data.posts.length}
            />
          ))}
        </div>
      </section>
    )}

    {/* Blog Posts Grid */}
    <section>
      <h2 class="text-2xl font-semibold text-foreground mb-6">
        {page.currentPage === 1 ? 'Latest Posts' : `Posts - Page ${page.currentPage}`}
      </h2>
      
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mb-12">
        {page.data.map(post => (
          <BlogCard
            title={post.post.data.title}
            description={post.post.data.description}
            date={post.post.data.date}
            author={post.post.data.author}
            subjectId={post.subject.id}
            subject={post.subject.data.name}
            subjectColor={post.subject.data.color}
            image={post.post.data.image}
            slug={post.post.id}
            readingTime={getReadingTime(post.post.body)}
          />
        ))}
      </div>

      <Pagination
        currentPage={page.currentPage}
        totalPages={page.lastPage}
        baseUrl="/blog"
      />
    </section>
  </div>
</BaseLayout>
