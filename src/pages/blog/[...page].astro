---
import type { GetStaticPaths } from 'astro';
import { getReadingTime } from '@/utils/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import StoryCard from '@/components/StoryCard.astro';
import Pagination from '@/components/Pagination.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { getBlogViewModel } from '@/factories/view-model.factory';

export const getStaticPaths = (async ({ paginate }) => {
  const viewModel = getBlogViewModel();
  const overview = await viewModel.getOverview();
  
  return paginate(overview.posts, {
      pageSize: overview.postsPerPage,
      props: {
        stories: overview.stories,
        blogPage: overview.page
    }
  });
}) satisfies GetStaticPaths;

const { page, stories, blogPage } = Astro.props;
---

<BaseLayout title={blogPage.data.title} description={blogPage.data.description}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <SectionHeader page={blogPage} />

    {/* Featured Stories Section - only on first page */}
    {page.currentPage === 1 && stories.length > 0 && (
      <section data-section="stories" class="mb-16">
        <h2 class="text-2xl font-semibold text-foreground mb-6">Featured Stories</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {stories.map((story) => (
            <StoryCard
              title={story.data.title}
              description={story.data.description}
              date={story.data.date}
              image={story.data.image}
              slug={story.id}
              postCount={story.data.posts.length}
            />
          ))}
        </div>
      </section>
    )}

    {/* Blog Posts Grid */}
    <section>
      <h2 class="text-2xl font-semibold text-foreground mb-6">
        {page.currentPage === 1 ? 'Latest Posts' : `Posts - Page ${page.currentPage}`}
      </h2>
      
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mb-12">
        {page.data.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            author={post.data.author}
            subject={post.data.subject}
            image={post.data.image}
            slug={post.id}
            readingTime={getReadingTime(post.body)}
          />
        ))}
      </div>

      <Pagination
        currentPage={page.currentPage}
        totalPages={page.lastPage}
        baseUrl="/blog"
      />
    </section>
  </div>
</BaseLayout>
