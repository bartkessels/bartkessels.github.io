---
import type { SimplifiedSubject } from '@/models/subject.model';
import BaseLayout from './BaseLayout.astro';
import SubjectsBar from '@/components/SubjectsBar.astro';

interface Props {
  title: string;
  description: string;
  image: string;
  imageCaption: string;
  type?: 'website' | 'article';
  subjects?: SimplifiedSubject[],
  showSubjectsBar?: boolean;
  activePageId: string;
  tags?: string[];
}

const { title, tags = [], activePageId, description, image, imageCaption, subjects = [], showSubjectsBar = false, type = 'article' } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} type={type} showSubjectsBar={showSubjectsBar} activePageId={activePageId} tags={tags}>
  <SubjectsBar subjects={subjects} slot="subjects-bar" />

  <article>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <figure class="mb-8">
          <div class="w-full aspect-[21/9] bg-muted overflow-hidden rounded-lg">
            <img src={image} alt={title} class="w-full h-full object-cover" />
          </div>
          <figcaption class="text-center text-xs text-muted italic py-2 px-4 border-t border-border/50">
            {imageCaption}
          </figcaption>
        </figure>
      <slot />
    </div>
  </article>
</BaseLayout>
