---
import { Calendar, User, Clock } from '@lucide/astro';
import ArticleLayout from './ArticleLayout.astro';
import SubjectBadge from '@/components/SubjectBadge.astro';
import TagsList from '@/components/TagsList.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import StoryNavigation from '@/components/StoryNavigation.astro';
import type { CollectionEntry } from 'astro:content';
import type { SimplifiedSubject } from '@/models/subject.model';

interface Props {
  post: CollectionEntry<'blog'>;
  formattedDate: string;
  relatedPosts?: CollectionEntry<'blog'>[];
  story: CollectionEntry<'stories'> | null;
  previousPost: CollectionEntry<'blog'> | null;
  nextPost: CollectionEntry<'blog'> | null;
  subject: CollectionEntry<'subjects/blog'>;
  subjects?: SimplifiedSubject[];
  showSubjectsBar?: boolean;
  readingTime?: number;
  activePageId: string;
  tags?: string[]
}

const {
  post,
  activePageId,
  relatedPosts = [],
  previousPost,
  nextPost,
  subject,
  formattedDate,
  readingTime,
  story,
  subjects = [],
  showSubjectsBar = false,
  tags = []
} = Astro.props;


const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: 'https://bartkessels.net/about',
  },
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  url: Astro.url.href,
  image: new URL(post.data.image, Astro.site).href,
};
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  imageCaption={post.data.caption}
  type="article"
  subjects={subjects}
  showSubjectsBar={showSubjectsBar}
  activePageId={activePageId}
  tags={tags}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />

  {/* Article Header */}
  <header class="mb-8">
    <div class="mb-2">
      <SubjectBadge subject={subject.data.name} color={subject.data.color} size="md" />
    </div>
    {(post.data.tags ?? []).length > 0 && (
      <div class="mb-4">
        <TagsList tags={post.data.tags ?? []} />
      </div>
    )}

    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4 leading-tight">
      {post.data.title}
    </h1>

    <p class="text-lg text-muted mb-6">
      {post.data.description}
    </p>

    <div class="flex flex-wrap items-center gap-6 text-sm text-muted border-b border-border pb-6">
      <span class="flex items-center gap-2">
        <User class="h-4 w-4" aria-hidden="true" />
        {post.data.author}
      </span>
      <time datetime={post.data.date.toISOString()} class="flex items-center gap-2">
        <Calendar class="h-4 w-4" aria-hidden="true" />
        {formattedDate}
      </time>
      {readingTime && (
        <span class="flex items-center gap-2">
          <Clock class="h-4 w-4" aria-hidden="true" />
          {readingTime} min read
        </span>
      )}
    </div>

    {/* Story link */}
    {story && (
      <div class="mt-6 p-4 bg-accent/5 rounded-lg border border-accent/20">
        <p class="text-sm text-muted mb-1">Part of the series</p>
        <a
          href={`/stories/${story.id}`}
          class="font-semibold text-accent hover:text-accent/80 transition-colors"
        >
          {story.data.title}
        </a>
      </div>
    )}
  </header>

  <div class="prose">
    <slot />
  </div>

  <StoryNavigation previousPost={previousPost} nextPost={nextPost} />

  {relatedPosts && !story && (
    <RelatedPosts relatedPosts={relatedPosts} />
  )}
</ArticleLayout>
